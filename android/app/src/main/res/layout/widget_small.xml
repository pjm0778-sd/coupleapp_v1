<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="@drawable/widget_background">

    <!-- D+N 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_d_plus_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="D+"
            android:textSize="11sp"
            android:textColor="#CBA258"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_d_days"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="---"
            android:textSize="26sp"
            android:textColor="#3D3535"
            android:textStyle="bold"
            android:lineSpacingExtra="-4sp" />

        <TextView
            android:id="@+id/tv_heart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💑"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- 구분선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0D8CC"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="7dp" />

    <!-- 나 일정 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="22dp"
            android:layout_height="wrap_content"
            android:text="나"
            android:textSize="9sp"
            android:textColor="#9E8E8E" />

        <TextView
            android:id="@+id/tv_my_schedule"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="여유로운 하루"
            android:textSize="10sp"
            android:textColor="#3D3535"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- 파트너 일정 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/tv_partner_label"
            android:layout_width="22dp"
            android:layout_height="wrap_content"
            android:text="파트"
            android:textSize="9sp"
            android:textColor="#9E8E8E" />

        <TextView
            android:id="@+id/tv_partner_schedule"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="여유로운 하루"
            android:textSize="10sp"
            android:textColor="#3D3535"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

</LinearLayout>
